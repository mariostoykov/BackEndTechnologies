    {
      "name": "Get All Lists from a Board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function() {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 30 seconds\", function() {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(30000);\r",
              "});\r",
              "\r",
              "const responseArray = pm.response.json(); // Declare once, reuse everywhere\r",
              "\r",
              "pm.test(\"Response is an array\", function() {\r",
              "    pm.expect(responseArray).to.be.an('array');\r",
              "});\r",
              "\r",
              "pm.test(\"Response array is not empty\", function() {\r",
              "    pm.expect(responseArray).to.not.be.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"Response array has 4 lists\", function() {\r",
              "    pm.expect(responseArray.length).to.eql(4);\r",
              "});\r",
              "\r",
              "pm.test(\"List with a specific name is present\", function() {\r",
              "    var listNames = responseArray.map((list) => list.name);\r",
              "    pm.expect(listNames).to.include(pm.variables.get(\"uniqueListName\"));\r",
              "});\r",
              "\r",
              "// Find the \"To Do\" list and save its ID for use in later requests\r",
              "const todoList = responseArray.find(list => list.name === \"To Do\");\r",
              "pm.collectionVariables.set(\"todoListId\", todoList.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
