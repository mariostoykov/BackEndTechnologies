    {
      "name": "Create a List with unique name on your board",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generate a unique name for the list using a random number:\r",
              "var uniqueName = \"List-\" + Math.floor(Math.random() * 100000);\r",
              "\r",
              "// Set this unique name as a variable\r",
              "pm.collectionVariables.set(\"uniqueListName\", uniqueName);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function() {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time is less than 30 seconds\", function() {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(30000);\r",
              "});\r",
              "\r",
              "const responseData = pm.response.json();\r",
              "\r",
              "pm.test(\"List name matches the unique name used in creation\", function() {\r",
              "    const expectedName = pm.variables.get(\"uniqueListName\");\r",
              "    pm.expect(responseData.name).to.eql(expectedName);\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"uniqueListId\", responseData.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
